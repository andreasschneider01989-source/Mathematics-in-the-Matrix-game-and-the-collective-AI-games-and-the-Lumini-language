/**
 * OPTIMIERTER GAME-LOOP
 * Mit adaptiver Schwierigkeit und fairem Punktesystem
 */
public class MathematicsMatrixgameLuminiOptimiert {
    
    private int gesamtPunkte = 0;
    private int level = 1;
    private int richtigeAntworten = 0;
    private int falscheAntworten = 0;
    private double durchschnittlichePunkte = 0;
    
    public void run() {
        println("╔══════════════════════════════════════════════╗");
        println("║  LUMINI MATRIXGAME v2.0                      ║");
        println("║  Adaptives Punktesystem • Faire Bewertung    ║");
        println("╚══════════════════════════════════════════════╝");
        println();
        
        while (true) {
            int questTyp = waehleQuestTyp();
            Schwierigkeit schw = bestimmeSchwierigkeit(level);
            
            boolean korrekt = bearbeiteQuest(questTyp, schw);
            
            int punkte = berechneAdaptivePunkte(korrekt, schw, level);
            gesamtPunkte += punkte;
            
            if (korrekt) {
                richtigeAntworten++;
                println("✓ RICHTIG! +" + punkte + " XP");
            } else {
                falscheAntworten++;
                println("✗ Falsch. " + punkte + " XP");
                println("  (Keine Sorge – beim nächsten Mal klappt's!)");
            }
            
            zeigeStats();
            
            // Level-Up Check
            if (richtigeAntworten >= level * 3) {
                level++;
                println("🎉 LEVEL UP! Du bist jetzt Level " + level);
                println("   Schwierigkeit und Punkte erhöhen sich!");
            }
            
            // Pause-Option
            if (gesamtPunkte % 100 == 0) {
                println("\n🌟 MEILENSTEIN! " + gesamtPunkte + " XP erreicht!");
                println("   Möchtest du eine Pause machen? (j/n)");
                String pause = readLine();
                if (pause.equalsIgnoreCase("j")) break;
            }
        }
        
        zeigeAbschlussStatistik();
    }
    
    private int berechneAdaptivePunkte(boolean korrekt, Schwierigkeit schw, int lvl) {
        if (!korrekt) {
            // Fairer Abzug: Maximal 10% des aktuellen Levels
            return -(int) Math.ceil(lvl * 0.5);
        }
        
        // Basis-Punkte × Schwierigkeit × Level-Faktor
        double basisPunkte = 10;
        double levelBonus = 1 + (lvl - 1) * 0.1;
        
        return (int) Math.round(basisPunkte * schw.getMultiplikator() * levelBonus);
    }
    
    private void zeigeStats() {
        double quote = (richtigeAntworten + falscheAntworten > 0) 
            ? (double) richtigeAntworten / (richtigeAntworten + falscheAntworten) * 100 
            : 0;
        
        println("\n╔══════════════════════════════════╗");
        println("║  STATS:                          ║");
        println("║  Level: " + level);
        println("║  Gesamt-XP: " + gesamtPunkte);
        println("║  Richtig: " + richtigeAntworten);
        println("║  Falsch: " + falscheAntworten);
        println("║  Trefferquote: " + String.format("%.1f", quote) + "%");
        println("╚══════════════════════════════════╝\n");
    }
}
