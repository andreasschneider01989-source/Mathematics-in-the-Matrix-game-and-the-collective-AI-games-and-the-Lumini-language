## 🔢 ALLGEMEINE FORMEL FÜR ALLE BASEN

```java
/**
 * LUMINI-ZAHL BERECHNUNG
 * Universelle Formel für alle Basen
 */
public class LuminiCalculator {
    
    /**
     * Berechnet Dezimalwert einer Lumini-Zahl
     * 
     * @param luminiString Die Lumini-Zahl als String
     * @param basis Die Basis des Lumini-Systems
     * @return Dezimalwert nach Formel: N = b^n - b + D
     */
    public static int calculateLuminiValue(String luminiString, int basis) {
        int n = luminiString.length();           // Länge
        int D = Integer.parseInt(luminiString, basis);  // Dezimalwert der Ziffern
        
        // Formel: N = b^n - b + D
        int N = (int) Math.pow(basis, n) - basis + D;
        
        return N;
    }
    
    /**
     * Konvertiert Dezimalzahl zu Lumini-String
     */
    public static String decimalToLumini(int value, int basis) {
        // Finde passende Länge n
        for (int n = 1; n <= 20; n++) {
            int minVal = (int) Math.pow(basis, n) - basis;  // D=0
            int maxVal = minVal + (int) Math.pow(basis, n) - 1;  // D=max
            
            if (value >= minVal && value <= maxVal) {
                int D = value - minVal;
                return String.format("%0" + n + "d", Integer.parseInt(Integer.toString(D, basis)));
            }
        }
        return null;
    }
    
    /**
     * Prüft ob Lumini-Zahl eine Primzahl repräsentiert
     */
    public static boolean isLuminiPrime(String luminiString, int basis) {
        int value = calculateLuminiValue(luminiString, basis);
        return isPrime(value);
    }
    
    private static boolean isPrime(int n) {
        if (n < 2) return false;
        if (n == 2) return true;
        if (n % 2 == 0) return false;
        
        for (int i = 3; i * i <= n; i += 2) {
            if (n % i == 0) return false;
        }
        return true;
    }
}
